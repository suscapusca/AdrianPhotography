{
  "name": "schipor-adrian-portfolio",
  "version": "1.0.0",
  "description": "Premium photographer portfolio and admin workspace for Schipor Adrian.",
  "main": "dist-server/server/index.js",
  "scripts": {
    "dev": "concurrently -k -n server,client -c cyan,yellow \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.server.json --noEmit",
    "start": "node dist-server/server/index.js"
  },
  "keywords": [
    "photography",
    "portfolio",
    "react",
    "vite",
    "express",
    "admin-dashboard"
  ],
  "author": "OpenAI Codex",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "gsap": "^3.14.2",
    "multer": "^2.1.1",
    "nanoid": "^5.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2"
  }
}
